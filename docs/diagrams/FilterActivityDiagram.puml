@startuml
skin rose
skinparam ActivityFontSize 15
skinparam ArrowFontSize 12

start
:Tokenize args with ArgumentTokenizer\n(crs/, tg/, p/, abs/);

if (Invalid prefix found?) then (yes)
    :Throw ParseException\n(invalid prefix);
    stop
else (no)
endif

if (Unexpected preamble text?) then (yes)
    :Throw ParseException\n(unexpected preamble);
    stop
else (no)
endif

if (Duplicate prefix used?) then (yes)
    :Throw ParseException\n(duplicate prefix);
    stop
else (no)
endif

if (Blank value after prefix?) then (yes)
    :Throw ParseException\n(empty value for prefix);
    stop
else (no)
endif

if (At least one filter present?) then (no)
    :Throw ParseException\n(no filters provided);
    stop
else (yes)
endif

:Parse each present field via ParserUtil\n(CourseId, TGroup, Progress, Integer);
:Create FilterMatchesPredicate\n(with Optional fields);
:Return FilterCommand;
stop
@enduml
