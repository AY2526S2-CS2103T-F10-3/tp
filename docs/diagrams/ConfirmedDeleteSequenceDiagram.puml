@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":LogicManager" as LogicManager LOGIC_COLOR
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant "c:ConfirmCommand" as ConfirmCommand LOGIC_COLOR
participant "cm:ConfirmationManager" as ConfirmationManager LOGIC_COLOR
participant "cd:ConfirmedDeleteCommand" as ConfirmedDeleteCommand LOGIC_COLOR
participant "r:CommandResult" as CommandResult LOGIC_COLOR
end box

box Model MODEL_COLOR_T1
participant "m:Model" as Model MODEL_COLOR
end box

[-> LogicManager : execute("yes")
activate LogicManager

LogicManager -> AddressBookParser : parseCommand("yes")
activate AddressBookParser

create ConfirmCommand
AddressBookParser -> ConfirmCommand
activate ConfirmCommand

ConfirmCommand --> AddressBookParser
deactivate ConfirmCommand

AddressBookParser --> LogicManager : c
deactivate AddressBookParser

LogicManager -> ConfirmCommand : execute(m)
activate ConfirmCommand

ConfirmCommand -> ConfirmationManager : getPendingCommand()
activate ConfirmationManager
ConfirmationManager --> ConfirmCommand : cd
deactivate ConfirmationManager

ConfirmCommand -> ConfirmationManager : clearPendingCommand()
activate ConfirmationManager
ConfirmationManager --> ConfirmCommand
deactivate ConfirmationManager

ConfirmCommand -> ConfirmedDeleteCommand : execute(m)
activate ConfirmedDeleteCommand

ConfirmedDeleteCommand -> Model : deletePerson(personToDelete)
activate Model
Model --> ConfirmedDeleteCommand
deactivate Model

create CommandResult
ConfirmedDeleteCommand -> CommandResult
activate CommandResult
CommandResult --> ConfirmedDeleteCommand
deactivate CommandResult

ConfirmedDeleteCommand --> ConfirmCommand : r
deactivate ConfirmedDeleteCommand

ConfirmCommand --> LogicManager : r
deactivate ConfirmCommand

[<--LogicManager
deactivate LogicManager
@enduml